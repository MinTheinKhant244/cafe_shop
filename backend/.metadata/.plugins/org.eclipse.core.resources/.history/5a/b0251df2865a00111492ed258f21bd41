package com.hmi.cafe_shop.entity;

public class LoginRequest {
    private String token;
    private User user;

    public AuthResponse(String token, User user) {
        this.token = token;
        this.user = user;
    }

    // Getters and Setters ...
    public String getToken() { return token; }
    public User Burger() { return user; }
}