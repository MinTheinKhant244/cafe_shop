package com.hmi.cafe_shop.repository;

import com.hmi.cafe_shop.entity.Order;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.stereotype.Repository;
import java.util.List;
import java.util.Optional;

@Repository
public interface OrderRepository extends JpaRepository<Order, Long> {
    Optional<Order> findByInvoiceNo(String invoiceNo);
    List<Order> findByStatus(String status);
    
 // TODAY SALES
    @Query("SELECT SUM(o.totalAmount) FROM Order o WHERE DATE(o.createdAt) = CURRENT_DATE")
    Double getTodaySales();

    // DAILY BY DATE
    @Query("SELECT SUM(o.totalAmount) FROM Order o WHERE DATE(o.createdAt) = :date")
    Double getTotalSalesByDate(@Param("date") LocalDate date);

    // MONTHLY SALES
    @Query("SELECT SUM(o.totalAmount) FROM Order o WHERE YEAR(o.createdAt) = :year AND MONTH(o.createdAt) = :month")
    Double getTotalSalesByMonth(@Param("year") int year, @Param("month") int month);

    // ORDER COUNT
    @Query("SELECT COUNT(o) FROM Order o WHERE DATE(o.createdAt) = CURRENT_DATE")
    Long countOrdersByDate(LocalDate date);

    @Query("SELECT COUNT(o) FROM Order o WHERE YEAR(o.createdAt) = :year AND MONTH(o.createdAt) = :month")
    Long countOrdersByMonth(int year, int month);

    @Query("SELECT COUNT(o) FROM Order o")
    Long countAllOrders();

    @Query("SELECT COUNT(o) FROM Order o WHERE o.status = 'PENDING'")
    Long countPendingOrders();

    // MONTHLY SALES SIMPLE
    @Query("SELECT SUM(o.totalAmount) FROM Order o WHERE YEAR(o.createdAt) = YEAR(CURRENT_DATE) AND MONTH(o.createdAt) = MONTH(CURRENT_DATE)")
    Double getMonthlySales();
}